# ==============================================================================
# AWS Configuration for Tamil Web (பூ வாசம்)
# ==============================================================================

# ------------------------------------------------------------------------------
# Server-Only AWS Configuration (NOT exposed to browser)
# Remove NEXT_PUBLIC_ prefix to keep these server-side only
# ------------------------------------------------------------------------------
AWS_REGION=ca-central-1
DYNAMODB_TABLE_NAME=TamilWebContent
S3_BUCKET=tamil-web-media

# ------------------------------------------------------------------------------
# AWS Credentials (Local Development Only)
# In AWS Amplify deployment, DO NOT set these - the service role provides credentials
# For local development, get these from AWS IAM Console
# ------------------------------------------------------------------------------
# AWS_ACCESS_KEY_ID=your-access-key-here
# AWS_SECRET_ACCESS_KEY=your-secret-access-key-here

# ------------------------------------------------------------------------------
# Cognito Configuration (Public - exposed to browser for Auth UI)
# These REQUIRE NEXT_PUBLIC_ prefix for Amplify UI components to work in browser
# Get these values from AWS Cognito Console
# ------------------------------------------------------------------------------
NEXT_PUBLIC_AWS_REGION=ca-central-1
NEXT_PUBLIC_USER_POOL_ID=ca-central-1_XXXXXXXXX
NEXT_PUBLIC_USER_POOL_CLIENT_ID=XXXXXXXXXXXXXXXXXXXXXXXXXX
NEXT_PUBLIC_IDENTITY_POOL_ID=ca-central-1:XXXXXXXX-XXXX-XXXX-XXXX-XXXXXXXXXXXX

# ------------------------------------------------------------------------------
# Application Configuration
# ------------------------------------------------------------------------------
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Poo Vaasam
NEXT_PUBLIC_MAX_FILE_SIZE=10485760

# ------------------------------------------------------------------------------
# Admin Configuration (Server-only)
# ------------------------------------------------------------------------------
ADMIN_SECRET_KEY=change-this-to-a-secure-random-string-in-production
