# AWS Configuration
NEXT_PUBLIC_AWS_REGION=us-east-1

# AWS Cognito
NEXT_PUBLIC_USER_POOL_ID=us-east-1_xxxxx
NEXT_PUBLIC_USER_POOL_CLIENT_ID=xxxxx
NEXT_PUBLIC_IDENTITY_POOL_ID=xxxxx

# DynamoDB
NEXT_PUBLIC_DYNAMODB_TABLE_NAME=TamilWebContent

# S3 Storage
NEXT_PUBLIC_S3_BUCKET=tamil-web-media
NEXT_PUBLIC_S3_REGION=us-east-1

# AWS Credentials (Server-side only - DO NOT expose these publicly)
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here

# GraphQL API (if using AppSync)
NEXT_PUBLIC_GRAPHQL_ENDPOINT=https://xxxxx.appsync-api.us-east-1.amazonaws.com/graphql

# Application Configuration
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Poo Vaasam
NEXT_PUBLIC_MAX_FILE_SIZE=10485760

# Admin Configuration
ADMIN_SECRET_KEY=change-this-to-a-secure-random-string

# Environment
NODE_ENV=development
